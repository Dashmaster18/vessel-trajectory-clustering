# 2) Upload CSV
print("📤 Please upload your AIS CSV file (use the file provided).")
uploaded = files.upload()
fname = list(uploaded.keys())[0]
print("Loaded file:", fname)

df = pd.read_csv(fname)
print("Initial shape:", df.shape)
